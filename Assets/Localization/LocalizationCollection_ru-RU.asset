  - m_Id: 92902035945414656
    m_Localized: "\u0416\u0435\u043B\u0435\u0437\u043D\u0430\u044F \u0440\u0443\u0434\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035987357696
    m_Localized: "\u0411\u0430\u0437\u043E\u0432\u0430\u044F \u0440\u0443\u0434\u0430.
      \u0418\u0433\u0440\u0430\u0435\u0442 \u0431\u043E\u043B\u044C\u0448\u0443\u044E
      \u0440\u043E\u043B\u044C \u0432 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435,
      \u0442\u0430\u043A \u043A\u0430\u043A \u0441\u043B\u0443\u0436\u0438\u0442
      \u043E\u0441\u043D\u043E\u0432\u044B\u043C \u0441\u044B\u0440\u044C\u0435\u043C
      \u0434\u043B\u044F \u0441\u0442\u0430\u043B\u0438\u043B\u0438\u0442\u0435\u0439\u043D\u043E\u0439
      \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552000
    m_Localized: "\u0416\u0435\u043B\u0435\u0437\u043D\u044B\u0439 \u0441\u043B\u0438\u0442\u043E\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552001
    m_Localized: "\u0421\u043B\u0438\u0442\u043A\u0438 \u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E
      \u0436\u0435\u043B\u0435\u0437\u0430, \u0431\u0435\u0437 \u043F\u0440\u0438\u043C\u0435\u0441\u0435\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552002
    m_Localized: "\u042F\u0449\u0438\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552003
    m_Localized: "\u0414\u043E\u0431\u0440\u043E\u0442\u043D\u044B\u0439 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u044B\u0439
      \u044F\u0449\u0438\u043A \u043E\u0431\u044A\u0435\u043C\u043E\u043C \u0432
      \u043E\u0434\u043D\u0443 \u0442\u043E\u043D\u043D\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552004
    m_Localized: "\u0421\u0443\u043C\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552005
    m_Localized: "\u0411\u0435\u0440\u0438, \u043A\u043B\u0430\u0434\u0438, \u043D\u0435\u0441\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552006
    m_Localized: "\u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B \u0446\u0438\u0430\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552007
    m_Localized: "\u041B\u0443\u0447\u0448\u0435 \u043D\u0435 \u0442\u0440\u043E\u0433\u0430\u0439
      \u0435\u0433\u043E \u0440\u0443\u043A\u0430\u043C\u0438 \u0431\u0435\u0437
      \u043F\u0435\u0440\u0447\u0430\u0442\u043E\u043A. \u0418 \u0432\u043E\u043E\u0431\u0449\u0435
      \u043D\u0435 \u0442\u0440\u043E\u0433\u0430\u0439. \u0410 \u0442\u0430\u043A
      \u0436\u0435, \u043F\u0440\u043E\u0432\u0435\u0440\u044C \u0444\u0438\u043B\u044C\u0442\u0440
      \u0432 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0433\u0430\u0437\u0435 \u0438
      \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C
      \u043A\u043E\u0441\u0442\u044E\u043C\u0430. \u042D\u0442\u0438 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u044B
      \u0445\u043E\u0440\u043E\u0448\u043E \u043F\u0440\u043E\u0440\u0430\u0441\u0442\u0430\u044E\u0442
      \u043D\u0430 \u043E\u0440\u0433\u0430\u043D\u0438\u043A\u0435, \u0438 \u0435\u0441\u043B\u0438
      \u0442\u044B \u043D\u0435 \u0436\u0443\u043A-\u0446\u0438\u0430\u043D\u0438\u0434
      \u0438 \u043D\u0435 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435 \u0438\u0437
      \u0436\u0451\u043B\u0442\u043E\u0439 \u0437\u043E\u043D\u044B, \u0442\u043E
      \u0432\u0440\u044F\u0434 \u043B\u0438 \u0443 \u0442\u0435\u0431\u044F \u0435\u0441\u0442\u044C
      \u043A \u043D\u0435\u043C\u0443 \u0438\u043C\u043C\u0443\u043D\u0438\u0442\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552008
    m_Localized: "\u041A\u0430\u0442\u0430\u043B\u0442\u0438\u0442\u043E\u0432\u0430\u044F
      \u0440\u0443\u0434\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552009
    m_Localized: "\u041F\u043E\u043B\u0435\u0437\u043D\u043E\u0435 \u0438\u0441\u043A\u043E\u043F\u0430\u0435\u043C\u043E\u0435.
      \u041E\u0431\u0440\u0430\u0437\u0443\u0435\u0442\u0441\u044F \u0438\u0437 \u0434\u0440\u0435\u0432\u043D\u0438\u0445
      \u043E\u0441\u0442\u0430\u0442\u043A\u043E\u0432 \u0446\u0438\u0430\u043D\u043E\u0432\u044B\u0445
      \u0434\u0435\u0440\u0435\u0432\u044C\u0435\u0432. \u0418\u0437 \u043D\u0435\u0433\u043E
      \u0434\u0435\u043B\u0430\u044E\u0442 \u0432\u0435\u0441\u044C\u043C\u0430 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0435
      \u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
      \u0442\u043E\u043F\u043B\u0438\u0432\u043E - \u043A\u0430\u0442\u0430\u0437\u0438\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552010
    m_Localized: "\u041A\u0430\u0442\u0430\u0437\u0438\u043D-1"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552011
    m_Localized: "\u041D\u0435\u0434\u043E\u0440\u043E\u0433\u043E\u0435 \u0442\u043E\u043F\u043B\u0438\u0432\u043E.
      \u0421\u0430\u043C\u043E \u043F\u043E \u0441\u0435\u0431\u0435 \u043D\u0435
      \u0442\u043E\u043A\u0441\u0438\u0447\u043D\u043E, \u043D\u043E \u043F\u0440\u0438
      \u0441\u0436\u0438\u0433\u0430\u043D\u0438\u0438 \u0432\u044B\u0434\u0435\u043B\u044F\u0435\u0442
      \u043C\u0430\u0441\u0441\u0443 \u0432\u0440\u0435\u0434\u043D\u044B\u0445 \u0432\u0435\u0449\u0435\u0441\u0442\u0432.
      \u041E\u0431\u044B\u0447\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
      \u043A\u0430\u043A \u0447\u0430\u0441\u0442\u044C \u043E\u0442 \u0442\u043E\u043F\u043B\u0438\u0432\u043D\u043E\u0439
      \u0441\u043C\u0435\u0441\u0438 \u0441\u043E \u0441\u0432\u043E\u0435\u0439
      \u0431\u043E\u043B\u0435\u0435 \u043E\u0447\u0438\u0449\u0435\u043D\u043D\u043E\u0439
      \u0438 \u0434\u043E\u0440\u043E\u0433\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0435\u0439,
      \u043A\u0430\u0442\u043E\u0437\u0438\u043D\u043E\u043C-2. \u041D\u043E \u0434\u0430\u0436\u0435
      \u0442\u0430\u043A \u043E\u043D \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D
      \u043A \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044E \u0432
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0442\u043E\u043F\u043B\u0438\u0432\u0430
      \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u0445
      \u0433\u043E\u0440\u043E\u0434\u0430\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552012
    m_Localized: "\u041A\u0430\u0442\u0430\u0437\u0438\u043D-2"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552013
    m_Localized: "\u041E\u0447\u0438\u0449\u0435\u043D\u043D\u043E\u0435, \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0435
      \u0438 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0435 \u0442\u043E\u043F\u043B\u0438\u0432\u043E
      \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0432\u0438\u0434\u043E\u0432
      \u0442\u0435\u0445\u043D\u0438\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552014
    m_Localized: "\u041F\u0430\u043D\u0446\u0438\u0440\u044C \u0436\u0443\u043A\u0430-\u0446\u0438\u0430\u043D\u0438\u0434\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552015
    m_Localized: "\u041D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0445\u043E\u0440\u043E\u0448\u0438\u0439
      \u0442\u0440\u043E\u0444\u0435\u0439, \u043D\u043E \u0438 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A
      \u0445\u0438\u0442\u0438\u0440\u0435\u043D\u0438\u043D\u0430 - \u0432\u0435\u0441\u044C\u043C\u0430
      \u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0439 \u0434\u043E\u0431\u0430\u0432\u043A\u0438
      \u0432 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0435
      \u0441\u0442\u0430\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552016
    m_Localized: "\u0425\u0438\u0442\u0438\u0440\u0435\u043D\u0438\u043D \u0441\u044B\u0440\u043E\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552017
    m_Localized: "\u0418\u0437\u043C\u0435\u043B\u044C\u0447\u0451\u043D\u043D\u044B\u0435
      \u043F\u0430\u043D\u0446\u0438\u0440\u0438 \u0436\u0443\u043A\u043E\u0432-\u0446\u0438\u0430\u043D\u0438\u0434\u043E\u0432.
      \u041E\u0447\u0438\u0449\u0430\u044E\u0442\u0441\u044F \u0430\u0444\u0444\u0438\u043D\u043D\u0430\u0436\u0435\u043C
      \u0434\u043E \u0447\u0438\u0441\u0442\u043E\u0433\u043E \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0430,
      \u0434\u043B\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
      \u043F\u0440\u0438 \u043B\u0438\u0442\u044C\u0435 \u043E\u0441\u043E\u0431\u043E
      \u043F\u0440\u043E\u0447\u043D\u043E\u0439 \u0441\u0442\u0430\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552018
    m_Localized: "\u0425\u0438\u0442\u0438\u0440\u0435\u043D\u0438\u043D \u0447\u0438\u0441\u0442\u044B\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552019
    m_Localized: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
      \u0434\u043B\u044F \u043B\u0435\u0433\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
      \u0441\u0442\u0430\u043B\u0438, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0449\u0435\u0439\u0441\u044F
      \u0432 \u0441\u0438\u043B\u043E\u0432\u044B\u0445 \u043A\u0430\u0440\u043A\u0430\u0441\u0430\u0445,
      \u0431\u0440\u043E\u043D\u0435\u0432\u044B\u0445 \u043F\u043B\u0430\u0441\u0442\u0438\u043D\u0430\u0445
      \u0438 \u0431\u0440\u043E\u043D\u0435\u0431\u043E\u0439\u043D\u044B\u0445 \u0441\u043D\u0430\u0440\u044F\u0434\u0430\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552020
    m_Localized: "\u0413\u0440\u0443\u0437\u043E\u0432\u043E\u0439 \u043A\u043E\u043F\u0442\u0435\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552021
    m_Localized: "\u041A\u043E\u0440\u043F\u0443\u0441 \u0433\u0440\u0443\u0437\u043E\u0432\u043E\u0433\u043E
      \u044D\u043C\u0433\u0440\u0430\u043A\u043E\u043F\u0442\u0435\u0440\u0430, \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0433\u043E
      \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0432\u043E\u0437\u043A\u0438 \u0433\u0440\u0443\u0437\u043E\u0432
      \u0434\u043E \u0442\u043E\u043D\u043D\u044B \u043D\u0430 \u0441\u0440\u0435\u0434\u043D\u0438\u0435
      \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 92902035991552022
    m_Localized: "\u041A\u043E\u043A\u043F\u0438\u0442 \u043A\u043E\u043F\u0442\u0435\u0440\u0430,
      5 \u043E\u0441\u0435\u0439"
